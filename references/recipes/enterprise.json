{
  "key": "enterprise",
  "version": "1.0.0",
  "source": "Carbon/Atlassian-like (nominative reference; no code/token values copied). Color primitives shared with minimal-tech for pilot WCAG safety; differentiation in typography/space/shape/motion.",
  "toneAnchor": {
    "static_dynamic": 3,
    "cold_warm": 4,
    "serious_playful": 2,
    "classic_cutting_edge": 2,
    "minimal_rich": 4
  },
  "hardConstraintRules": {
    "requires": {
      "mediums": [
        "web"
      ]
    },
    "excludesAudiences": [],
    "minContrastCapable": true,
    "tags": [
      "web",
      "html",
      "high-contrast-capable",
      "dense-data"
    ]
  },
  "philosophy": {
    "principles": [
      "일관성과 신뢰",
      "정보 밀도 우선",
      "보수적 모션"
    ],
    "rationale": "엔터프라이즈 원형은 정보 밀도와 일관성을 우선한다. 넉넉한 여백 스케일과 보수적 모서리·모션으로 장시간 사용에도 피로가 낮은 화면을 만든다.",
    "decisionTrace": [
      {
        "axis": "tone_vector.minimal_rich",
        "value": 4,
        "rationale": "중간 채도 중성 팔레트로 정보 밀도와 가독성 균형",
        "coversTokenPath": [
          "semantic.color.surface.*",
          "semantic.color.primary.default",
          "primitive.color.*"
        ]
      },
      {
        "axis": "persona.archetype",
        "value": "enterprise",
        "rationale": "보수적 모서리와 절제된 전환 모션",
        "coversTokenPath": [
          "primitive.radius.*",
          "semantic.shape.*",
          "primitive.duration.*",
          "semantic.motion.*"
        ]
      },
      {
        "axis": "tone_vector.serious_playful",
        "value": 2,
        "rationale": "정보 밀도를 위한 또렷한 본문 램프와 넉넉한 여백 스케일",
        "coversTokenPath": [
          "primitive.font.*",
          "semantic.typography.*",
          "primitive.space.*",
          "semantic.space.*"
        ]
      }
    ]
  },
  "base": {
    "transformContract": {
      "dimension": {
        "web": {
          "base": 16,
          "unit": "rem"
        }
      },
      "duration": {
        "web": "ms"
      },
      "color": {
        "web": "oklch"
      }
    },
    "contrastPairs": [
