{
  "key": "minimal-tech",
  "version": "1.0.0",
  "source": "Geist-like (nominative reference; no code/token values copied)",
  "toneAnchor": {
    "static_dynamic": 2,
    "cold_warm": 3,
    "serious_playful": 3,
    "classic_cutting_edge": 5,
    "minimal_rich": 2
  },
  "hardConstraintRules": {
    "requires": {
      "mediums": [
        "web"
      ]
    },
    "excludesAudiences": [],
    "minContrastCapable": true,
    "tags": [
      "web",
      "html",
      "high-contrast-capable"
    ]
  },
  "philosophy": {
    "principles": [
      "명료성 우선",
      "기능색 최소",
      "정직한 여백"
    ],
    "rationale": "저채도 중성 팔레트에 기능색을 절제해 명료성을 우선한다. 엔지니어 원형은 모서리를 타이트하게, 모션을 절제하게 끌어당긴다.",
    "decisionTrace": [
      {
        "axis": "tone_vector.minimal_rich",
        "value": -0.6,
        "rationale": "저채도 중성 팔레트 + 기능색 최소화로 명료성 우선",
        "coversTokenPath": [
          "semantic.color.surface.*",
          "semantic.color.primary.default",
          "primitive.color.*"
        ]
      },
      {
        "axis": "persona.archetype",
        "value": "engineer",
        "rationale": "타이트한 모서리와 절제된 모션",
        "coversTokenPath": [
          "primitive.radius.*",
          "semantic.shape.*",
          "primitive.duration.*",
          "semantic.motion.*"
        ]
      },
      {
        "axis": "tone_vector.playful_serious",
        "value": 0.5,
        "rationale": "본문 가독성을 위한 균형 잡힌 sans 램프와 정직한 여백 스케일",
        "coversTokenPath": [
          "primitive.font.*",
          "semantic.typography.*",
          "primitive.space.*",
          "semantic.space.*"
        ]
      }
    ]
  },
  "base": {
    "transformContract": {
      "dimension": {
        "web": {
          "base": 16,
          "unit": "rem"
        }
      },
      "duration": {
        "web": "ms"
      },
      "color": {
        "web": "oklch"
      }
    },
    "contrastPairs": [
      {
        "fg": "semantic.color.surface.foreground",
        "bg": "semantic.color.surface.default",
        "role": "text",
        "state": "default"
      },
      {
        "fg": "semantic.color.primary.foreground",
        "bg": "semantic.color.primary.default",
        "role": "text",
        "state": "default"
      },
      {
        "fg": "semantic.color.primary.foreground",
        "bg": "semantic.color.primary.hover",
        "role": "text",
        "state": "hover"
      }
    ],
    "primitive": {
      "color": {
        "neutral": {
          "50": {
            "$type": "color",
            "$value": "oklch(0.98 0 0)",
            "$class": "portable",
            "$description": "최상위 표면 배경"
          },
          "100": {
            "$type": "color",
            "$value": "oklch(0.95 0 0)",
            "$class": "portable"
          },
          "600": {
            "$type": "color",
            "$value": "oklch(0.50 0 0)",
            "$class": "portable"
          },
          "900": {
