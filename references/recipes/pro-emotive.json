{
  "key": "pro-emotive",
  "version": "1.0.0",
  "source": "F2 Premium Editorial (Notion/Stripe/Apple-like; nominative reference). Warm-neutral + single warm accent, humanist body + serif heading, soft generous shapes.",
  "toneAnchor": {
    "static_dynamic": 3,
    "cold_warm": 5,
    "serious_playful": 3,
    "classic_cutting_edge": 5,
    "minimal_rich": 3
  },
  "hardConstraintRules": {
    "requires": {
      "mediums": [
        "web"
      ]
    },
    "excludesAudiences": [],
    "minContrastCapable": true,
    "tags": [
      "web",
      "html",
      "high-contrast-capable",
      "editorial"
    ]
  },
  "philosophy": {
    "principles": [
      "따뜻한 명료성",
      "에디토리얼 위계",
      "부드러운 신뢰"
    ],
    "rationale": "따뜻한 중성 팔레트와 단일 웜 accent로 친근하면서 세련된 인상을 만든다. 본문은 가독성 높은 휴머니스트 sans, 제목은 세리프로 에디토리얼 위계를 세우고, 넉넉한 여백과 부드러운 모서리로 긴장을 낮춘다.",
    "decisionTrace": [
      {
        "axis": "tone_vector.cold_warm",
        "value": 5,
        "rationale": "따뜻한 중성(웜 그레이)과 단일 웜 accent로 친근·세련 인상",
        "coversTokenPath": [
          "semantic.color.surface.*",
          "semantic.color.primary.default",
          "primitive.color.*"
        ]
      },
      {
        "axis": "persona.archetype",
        "value": "caregiver-sage",
        "rationale": "부드러운 모서리와 절제된 전환 모션",
        "coversTokenPath": [
          "primitive.radius.*",
          "semantic.shape.*",
          "primitive.duration.*",
          "semantic.motion.*"
        ]
      },
      {
        "axis": "tone_vector.classic_cutting_edge",
        "value": 5,
        "rationale": "휴머니스트 sans 본문 + 세리프 제목의 에디토리얼 위계와 넉넉한 여백",
        "coversTokenPath": [
          "primitive.font.*",
          "semantic.typography.*",
          "primitive.space.*",
          "semantic.space.*"
        ]
      }
    ]
  },
  "base": {
    "transformContract": {
      "dimension": {
        "web": {
          "base": 16,
          "unit": "rem"
        }
      },
      "duration": {
        "web": "ms"
      },
      "color": {
        "web": "oklch"
      }
    },
    "contrastPairs": [
      {
        "fg": "semantic.color.surface.foreground",
        "bg": "semantic.color.surface.default",
        "role": "text",
        "state": "default"
      },
      {
        "fg": "semantic.color.primary.foreground",
        "bg": "semantic.color.primary.default",
        "role": "text",
        "state": "default"
      },
      {
        "fg": "semantic.color.primary.foreground",
        "bg": "semantic.color.primary.hover",
        "role": "text",
        "state": "hover"
      },
      {
        "fg": "semantic.color.surface.foreground",
        "bg": "semantic.gradient.hero",
        "role": "text",
        "state": "default"
      }
    ],
    "primitive": {
      "color": {
        "neutral": {
          "50": {
            "$type": "color",
            "$value": "oklch(0.98 0.008 60)",
            "$class": "portable",
            "$description": "따뜻한 페이퍼 표면"
          },
          "100": {
            "$type": "color",
            "$value": "oklch(0.95 0.01 60)",
            "$class": "portable"
          },
          "600": {
            "$type": "color",
            "$value": "oklch(0.52 0.012 60)",
            "$class": "portable"
          },
          "900": {
            "$type": "color",
            "$value": "oklch(0.27 0.015 60)",
            "$class": "portable",
            "$description": "따뜻한 잉크 본문"
          }
        },
        "accent": {
          "600": {
            "$type": "color",
            "$value": "oklch(0.50 0.15 25)",
            "$class": "portable",
            "$description": "웜 로즈 프라이머리"
