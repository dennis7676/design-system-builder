{
  "key": "warm-creator",
  "version": "1.0.0",
  "source": "Mailchimp/Gumroad-like (nominative reference; no code/token values copied)",
  "toneAnchor": {
    "static_dynamic": 4,
    "cold_warm": 6,
    "serious_playful": 6,
    "classic_cutting_edge": 4,
    "minimal_rich": 5
  },
  "hardConstraintRules": {
    "requires": {
      "mediums": [
        "web"
      ]
    },
    "excludesAudiences": [],
    "minContrastCapable": true,
    "tags": [
      "web",
      "html",
      "high-contrast-capable",
      "warm"
    ]
  },
  "philosophy": {
    "principles": [
      "따뜻한 친근함",
      "표현적 활기",
      "인간적 라운딩"
    ],
    "rationale": "휴머니스트 산세리프와 둥근 형태 언어로 크리에이터의 온기를 전한다. 인디 원형은 모서리를 둥글게, 모션을 경쾌하게 끌어당긴다.",
    "decisionTrace": [
      {
        "axis": "tone_vector.minimal_rich",
        "value": 5,
        "rationale": "웜 코럴 포인트와 크림 표면으로 친근함 우선",
        "coversTokenPath": [
          "semantic.color.surface.*",
          "semantic.color.primary.default",
          "primitive.color.*"
        ]
      },
      {
        "axis": "persona.archetype",
        "value": "creator",
        "rationale": "둥근 모서리와 경쾌하고 빠른 전환",
        "coversTokenPath": [
          "primitive.radius.*",
          "semantic.shape.*",
          "primitive.duration.*",
          "semantic.motion.*"
        ]
      },
      {
        "axis": "tone_vector.serious_playful",
        "value": 6,
        "rationale": "휴머니스트 산세리프와 넉넉한 본문",
        "coversTokenPath": [
          "primitive.font.*",
          "semantic.typography.*",
          "primitive.space.*",
          "semantic.space.*"
        ]
      }
    ]
  },
  "base": {
    "transformContract": {
      "dimension": {
        "web": {
          "base": 16,
          "unit": "rem"
        }
      },
      "duration": {
        "web": "ms"
      },
      "color": {
        "web": "oklch"
      }
    },
    "contrastPairs": [
      {
        "fg": "semantic.color.surface.foreground",
        "bg": "semantic.color.surface.default",
        "role": "text",
        "state": "default"
      },
      {
        "fg": "semantic.color.primary.foreground",
        "bg": "semantic.color.primary.default",
        "role": "text",
        "state": "default"
      },
      {
        "fg": "semantic.color.primary.foreground",
        "bg": "semantic.color.primary.hover",
        "role": "text",
        "state": "hover"
      },
      {
        "fg": "semantic.color.surface.foreground",
        "bg": "semantic.gradient.hero",
        "role": "text",
        "state": "default"
      }
    ],
    "primitive": {
      "color": {
        "neutral": {
          "50": {
            "$type": "color",
            "$value": "oklch(0.98 0.012 70)",
            "$class": "portable",
            "$description": "최상위 표면 배경"
          },
          "100": {
            "$type": "color",
            "$value": "oklch(0.95 0.016 70)",
            "$class": "portable"
          },
          "600": {
            "$type": "color",
            "$value": "oklch(0.52 0.03 50)",
            "$class": "portable"
          },
          "900": {
            "$type": "color",
            "$value": "oklch(0.26 0.02 45)",
            "$class": "portable",
            "$description": "본문 텍스트"
